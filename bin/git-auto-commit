#!/usr/bin/env bash
# git-auto-commit — generate a Conventional / Angular-style commit message
# from staged changes using GitHub Models, then commit.
#
# Convention scanning:
#   Before calling the model, the script scans the repo root for local commit
#   guidelines in these locations (first match wins):
#     .github/instructions/commit-conventions.instructions.md
#     .github/instructions/commit*.instructions.md
#     .github/commit-conventions.md
#     .github/CONVENTIONS.md
#     CONVENTIONS.md
#     docs/commit-conventions.md
#     .copilot/commit-conventions.md
#     .squad/templates/commit.md
#   Any conventions found are injected into the system prompt so the model
#   follows repo-specific rules.
#
# Usage:
#   git auto-commit                       # stage-as-is, ask for confirmation
#   git auto-commit -a                    # also stage tracked modifications first
#   git auto-commit -y                    # skip confirmation prompt
#   git auto-commit --type=fix            # hint the commit type
#   git auto-commit --scope=ui            # hint the scope (comma-separated ok)
#   git auto-commit --ticket=ABC-123      # force a ticket id into scope
#   git auto-commit --no-ticket           # do NOT auto-add a ticket id
#   git auto-commit --model=openai/gpt-4o-mini
#   git auto-commit --dry-run             # print message, do not commit
#   git auto-commit --print               # just print to stdout (no commit, no prompt)
#   git auto-commit --no-body             # subject only
#   git auto-commit --no-sign-off         # skip DCO Signed-off-by trailer
#   git auto-commit --version
#
# Scope rules:
#   The generated subject is `<type>(<scope>): <subject>` where <scope> is a
#   comma-space separated list. A ticket id (default pattern: [A-Z][A-Z0-9]+-\d+)
#   detected from the branch name (e.g. feature/CNCRM-8729-foo) or recent
#   commit messages is auto-prepended as the first scope, followed by any
#   model-inferred or user-hinted scopes. e.g. feat(CNCRM-8729, auth, ui): ...
#
# DCO:
#   By default the final commit is created with `git commit -s`, appending a
#   `Signed-off-by:` trailer (idempotent — safe alongside the `git dco` hook).
#   Pass --no-sign-off to disable.
#
# Auth:
#   Uses $GITHUB_TOKEN if set, otherwise falls back to `gh auth token`.
#   The token needs `models:read` (default on personal tokens).
#
# Requirements: git, curl, jq. Optional: gh (for token fallback).

set -euo pipefail

# Resolve the script's directory to find the JSON manifest
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_JSON_PATH="$_SCRIPT_DIR/../bucket/git-auto-commit.json"

# Read VERSION from the canonical JSON manifest
if [ -f "$_JSON_PATH" ]; then
  VERSION="$(jq -r '.version' "$_JSON_PATH")"
else
  # Fallback for development / non-standard layouts
  VERSION="0.2.3"
fi

DEFAULT_MODEL="${GIT_AUTO_COMMIT_MODEL:-openai/gpt-4o-mini}"
API_URL="${GIT_AUTO_COMMIT_API:-https://models.github.ai/inference/chat/completions}"
MAX_DIFF_CHARS="${GIT_AUTO_COMMIT_MAX_DIFF:-12000}"
TICKET_PATTERN="${GIT_AUTO_COMMIT_TICKET_PATTERN:-[A-Z][A-Z0-9]+-[0-9]+}"

usage() { sed -n '2,36p' "$0" | sed 's/^# \{0,1\}//'; }

assume_yes=0
stage_all=0
dry_run=0
print_only=0
include_body=1
sign_off=1
no_ticket=0
type_hint=""
scope_hint=""
ticket_override=""
model="$DEFAULT_MODEL"

for arg in "$@"; do
  case "$arg" in
    -h|--help) usage; exit 0 ;;
    -V|--version) echo "git-auto-commit $VERSION"; exit 0 ;;
    -y|--yes) assume_yes=1 ;;
    -a|--all) stage_all=1 ;;
    --dry-run) dry_run=1 ;;
    --print) print_only=1; dry_run=1; assume_yes=1 ;;
    --no-body) include_body=0 ;;
    --sign-off|-s) sign_off=1 ;;
    --no-sign-off) sign_off=0 ;;
    --type=*) type_hint="${arg#*=}" ;;
    --scope=*) scope_hint="${arg#*=}" ;;
    --ticket=*) ticket_override="${arg#*=}" ;;
    --no-ticket) no_ticket=1 ;;
    --model=*) model="${arg#*=}" ;;
    *) echo "✗ Unknown argument: $arg" >&2; usage >&2; exit 2 ;;
  esac
done

command -v git >/dev/null 2>&1 || { echo "✗ git not found" >&2; exit 127; }
command -v curl >/dev/null 2>&1 || { echo "✗ curl not found" >&2; exit 127; }
command -v jq >/dev/null 2>&1 || { echo "✗ jq not found (brew install jq)" >&2; exit 127; }

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "✗ Not inside a git repository." >&2; exit 1;
}

if [ "$stage_all" = "1" ]; then
  git add -u
fi

if git diff --cached --quiet; then
  echo "✗ Nothing staged. Use -a to stage tracked changes, or 'git add' first." >&2
  exit 1
fi

resolve_token() {
  if [ -n "${GITHUB_TOKEN:-}" ]; then printf '%s' "$GITHUB_TOKEN"; return; fi
  if command -v gh >/dev/null 2>&1; then gh auth token 2>/dev/null || true; fi
}

TOKEN="$(resolve_token)"
if [ -z "$TOKEN" ]; then
  echo "✗ No token. Set GITHUB_TOKEN or run 'gh auth login'." >&2
  exit 1
fi

# Collect context for the model.
diff_stat="$(git diff --cached --stat)"
diff_body="$(git diff --cached --no-color)"
if [ "${#diff_body}" -gt "$MAX_DIFF_CHARS" ]; then
  diff_body="${diff_body:0:$MAX_DIFF_CHARS}

[... diff truncated at ${MAX_DIFF_CHARS} chars ...]"
fi
recent_log="$(git log -n 10 --pretty=format:'%s' 2>/dev/null || true)"
branch_name="$(git symbolic-ref --short HEAD 2>/dev/null || true)"

# Detect ticket id: explicit override > --no-ticket disables > branch name > recent commits.
ticket=""
if [ "$no_ticket" = "0" ]; then
  if [ -n "$ticket_override" ]; then
    ticket="$ticket_override"
  elif [ -n "$branch_name" ]; then
    ticket="$(printf '%s' "$branch_name" | grep -oE "$TICKET_PATTERN" | head -1 || true)"
  fi
  if [ -z "$ticket" ] && [ -n "$recent_log" ]; then
    ticket="$(printf '%s' "$recent_log" | grep -oE "$TICKET_PATTERN" | head -1 || true)"
  fi
fi

hint_line=""
if [ -n "$type_hint" ] || [ -n "$scope_hint" ] || [ -n "$ticket" ]; then
  hint_line="Hints from the user/context: "
  [ -n "$type_hint" ] && hint_line+="type=${type_hint} "
  [ -n "$scope_hint" ] && hint_line+="extra_scopes=${scope_hint} "
  [ -n "$ticket" ] && hint_line+="ticket=${ticket}"
fi

body_rule="A blank line, then a body of 1-4 short lines explaining what changed and why. \
Use imperative mood. Wrap each line at ~72 chars."
[ "$include_body" = "0" ] && body_rule="Do NOT include a body — output only the subject line."

# TICKET BAN applies whenever we have NO detected ticket — whether the user
# explicitly passed --no-ticket or we simply couldn't infer one. Prevents the
# model from hallucinating ids like TICKET-1 / ABC-123.
ticket_rule=""
if [ -z "$ticket" ]; then
  ticket_rule="- TICKET BAN: do NOT include any ticket id (e.g. ABC-123, PROJ-9999, TICKET-1, FOO-42) in the scope or anywhere in the message. No ticket was provided or detected; do not invent one."
fi

# Scan the repo for commit conventions / guidelines that the model should follow.
# Checks multiple locations in priority order.
CONVENTIONS=""
_scan_conventions() {
  local root="$1"
  # 1. .github/instructions/commit-conventions.instructions.md (or similar)
  for f in "$root"/.github/instructions/commit-conventions.instructions.md \
           "$root"/.github/instructions/commit*.instructions.md \
           "$root"/.github/commit-conventions.md \
           "$root"/.github/CONVENTIONS.md \
           "$root"/CONVENTIONS.md \
           "$root"/docs/commit-conventions.md \
           "$root"/.copilot/commit-conventions.md; do
    if [ -f "$f" ]; then
      CONVENTIONS+="$(cat "$f")"$'\n'
      break
    fi
  done
  # 2. .git/hooks/commit-msg sample or template
  if [ -z "$CONVENTIONS" ] && [ -f "$root/.git/hooks/commit-msg.sample" ]; then
    CONVENTIONS+="# commit-msg.sample found in .git/hooks/ — it may contain local conventions.\n"
  fi
  # 3. .squad/templates/commit.md or similar
  for f in "$root"/.squad/templates/commit.md \
           "$root"/.squad/templates/commit-message.md; do
    if [ -f "$f" ]; then
      CONVENTIONS+="$(cat "$f")"$'\n'
      break
    fi
  done
}
_repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
_scan_conventions "$_repo_root"

# Inject conventions into the system prompt if any were found.
conventions_rule=""
if [ -n "$CONVENTIONS" ]; then
  conventions_rule="- LOCAL CONVENTIONS: The repository has local commit guidelines. Follow them strictly:\n\n${CONVENTIONS}"
fi

read -r -d '' SYSTEM_PROMPT <<EOF || true
You write git commit messages that follow the Conventional Commits / Angular convention.

Output format — strictly:
  <type>(<scope>): <subject>
  ${body_rule}

Rules:
- type ∈ feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
- subject: imperative mood, lowercase, no trailing period, <= 72 chars
- scope: REQUIRED if any scope hint or ticket is provided. Format is a comma-space
  separated list inside the parentheses, e.g. feat(TICKET-1, auth, ui): ...
  - If a ticket is given in the hints, it MUST be the FIRST item in the scope list, verbatim (preserve case).
  - Then include any extra_scopes provided by the user, in order.
  - Then add 1-2 short lowercase scopes you infer from the diff (file/module/area names).
  - Drop duplicates. Keep scope total to <= 4 items.
- If no ticket and no hints and the diff is trivially single-area, scope is optional.
${ticket_rule}
- Match the language of recent commits (Chinese subject → Chinese body, English → English)
- For breaking changes, append "!" after the closing paren and add a "BREAKING CHANGE:" footer
${conventions_rule}
- Output ONLY the commit message — no code fences, no commentary, no "Here is..." preface
EOF

if [ "$print_only" = "1" ]; then
  printf '%s\n' "$message"
  exit 0
fi

echo "── proposed commit ───────────────────────────────"
printf '%s\n' "$message"
echo "──────────────────────────────────────────────────"

if [ "$dry_run" = "1" ]; then
  echo "(dry-run — not committing)"
  exit 0
fi

if [ "$assume_yes" = "0" ]; then
  if [ ! -t 0 ]; then
    echo "✗ Non-interactive shell — pass -y to commit without prompting." >&2
    exit 1
  fi
  printf "Commit with this message? [Y/n/e(dit)] "
  read -r reply </dev/tty
  case "${reply:-y}" in
    n|N|no|NO) echo "Aborted."; exit 1 ;;
    e|E|edit)
      tmp="$(mktemp -t git-auto-commit.XXXXXX)"
      printf '%s\n' "$message" > "$tmp"
      "${EDITOR:-vi}" "$tmp" </dev/tty >/dev/tty
      message="$(cat "$tmp")"
      rm -f "$tmp"
      [ -z "${message//[[:space:]]/}" ] && { echo "✗ Empty message."; exit 1; }
      ;;
    *) ;;
  esac
fi

tmp="$(mktemp -t git-auto-commit.XXXXXX)"
printf '%s\n' "$message" > "$tmp"
commit_args=(-F "$tmp")
[ "$sign_off" = "1" ] && commit_args+=(-s)
git commit "${commit_args[@]}"
rm -f "$tmp"

read -r -d '' USER_PROMPT <<EOF || true
${hint_line}

Current branch: ${branch_name:-<detached>}

Recent commit subjects (for style reference):
${recent_log:-<none>}

Staged diff stat:
${diff_stat}

Staged diff:
${diff_body}
EOF

payload="$(jq -n \
  --arg model "$model" \
  --arg sys "$SYSTEM_PROMPT" \
  --arg usr "$USER_PROMPT" \
  '{model: $model, temperature: 0.2,
    messages: [{role:"system", content:$sys}, {role:"user", content:$usr}]}')"

printf '🤖 Using model: %s\n' "$model"

# Fetch current GitHub user info from the token.
github_user=""
if command -v curl >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  user_resp="$(curl -sS -w '\n%{http_code}' -H "Authorization: token $TOKEN" \
    "https://api.github.com/user" 2>/dev/null || true)"
  user_http="$(printf '%s\n' "$user_resp" | tail -1)"
  if [ "$user_http" = "200" ]; then
    github_user="$(printf '%s\n' "$user_resp" | sed '$d' | jq -r '.login // empty' 2>/dev/null || true)"
  fi
fi
[ -n "$github_user" ] && printf '👤 GitHub: %s\n' "$github_user"

response="$(curl -sS -X POST "$API_URL" \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  -H "Accept: application/json" \
  --data-binary "$payload")"

message="$(printf '%s' "$response" | jq -r '.choices[0].message.content // empty' | \
  sed -e 's/^```[a-zA-Z]*$//' -e 's/^```$//' | \
  awk 'NF || p {p=1; print}')"

# Trim trailing blank lines.
message="$(printf '%s\n' "$message" | awk '
  { lines[NR]=$0 }
  END {
    n=NR
    while (n>0 && lines[n] ~ /^[[:space:]]*$/) n--
    for (i=1;i<=n;i++) print lines[i]
  }')"

if [ -z "$message" ]; then
  echo "✗ Model returned an empty message." >&2
  echo "--- raw response ---" >&2
  printf '%s\n' "$response" | head -40 >&2
  exit 1
fi

# Safety net: if a ticket was detected but the model dropped it, inject it as
# the first scope. Also normalize scope separators to ", ".
if [ -n "$ticket" ]; then
  first_line="$(printf '%s\n' "$message" | head -1)"
  rest="$(printf '%s\n' "$message" | tail -n +2)"
  if printf '%s' "$first_line" | grep -qE "^[a-z]+(\(.+\))?!?: "; then
    # Already conventional. Check whether the ticket is already in the scope.
    if ! printf '%s' "$first_line" | grep -qF "$ticket"; then
      if printf '%s' "$first_line" | grep -qE "^[a-z]+\(.+\)!?: "; then
        # Has a scope — prepend ticket inside parens.
        first_line="$(printf '%s' "$first_line" | sed -E "s/^([a-z]+)\(([^)]+)\)(!?: )/\1(${ticket}, \2)\3/")"
      else
        # No scope — add one.
        first_line="$(printf '%s' "$first_line" | sed -E "s/^([a-z]+)(!?): /\1(${ticket})\2: /")"
      fi
    fi
    if [ -n "$rest" ]; then
      message="${first_line}
${rest}"
    else
      message="$first_line"
    fi
  fi
else
  # Safety net: NO ticket detected/provided — scrub any hallucinated ticket id
  # the model may have stuffed into the scope, even though the prompt forbade
  # it. Operates on the subject line only.
  first_line="$(printf '%s\n' "$message" | head -1)"
  rest="$(printf '%s\n' "$message" | tail -n +2)"
  if printf '%s' "$first_line" | grep -qE "^[a-z]+\(.+\)!?: "; then
    scope="$(printf '%s' "$first_line" | sed -E "s/^[a-z]+\(([^)]+)\)!?: .*$/\1/")"
    # Drop any comma-separated item that matches the ticket pattern.
    cleaned="$(printf '%s' "$scope" | awk -v pat="^${TICKET_PATTERN}\$" '
      BEGIN { FS=","; OFS=", " }
      {
        n=0
        for (i=1;i<=NF;i++) {
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", $i)
          if ($i !~ pat && $i != "") { n++; out[n]=$i }
        }
        for (i=1;i<=n;i++) { printf "%s%s", out[i], (i<n?", ":"") }
      }')"
    if [ -z "$cleaned" ]; then
      # Scope was nothing but a hallucinated ticket — drop the parens entirely.
      first_line="$(printf '%s' "$first_line" | sed -E "s/^([a-z]+)\([^)]+\)(!?: )/\1\2/")"
    elif [ "$cleaned" != "$scope" ]; then
      first_line="$(printf '%s' "$first_line" | sed -E "s/^([a-z]+)\([^)]+\)(!?: )/\1(${cleaned})\2/")"
    fi
    if [ -n "$rest" ]; then
      message="${first_line}
${rest}"
    else
      message="$first_line"
    fi
  fi
fi

if [ "$print_only" = "1" ]; then
  printf '%s\n' "$message"
  exit 0
fi

echo "── proposed commit ───────────────────────────────"
printf '%s\n' "$message"
echo "──────────────────────────────────────────────────"

if [ "$dry_run" = "1" ]; then
  echo "(dry-run — not committing)"
  exit 0
fi

if [ "$assume_yes" = "0" ]; then
  if [ ! -t 0 ]; then
    echo "✗ Non-interactive shell — pass -y to commit without prompting." >&2
    exit 1
  fi
  printf "Commit with this message? [Y/n/e(dit)] "
  read -r reply </dev/tty
  case "${reply:-y}" in
    n|N|no|NO) echo "Aborted."; exit 1 ;;
    e|E|edit)
      tmp="$(mktemp -t git-auto-commit.XXXXXX)"
      printf '%s\n' "$message" > "$tmp"
      "${EDITOR:-vi}" "$tmp" </dev/tty >/dev/tty
      message="$(cat "$tmp")"
      rm -f "$tmp"
      [ -z "${message//[[:space:]]/}" ] && { echo "✗ Empty message."; exit 1; }
      ;;
    *) ;;
  esac
fi

tmp="$(mktemp -t git-auto-commit.XXXXXX)"
printf '%s\n' "$message" > "$tmp"
commit_args=(-F "$tmp")
[ "$sign_off" = "1" ] && commit_args+=(-s)
git commit "${commit_args[@]}"
rm -f "$tmp"
